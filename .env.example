# ---------------------------------------------------------------------------
# Mail server
# ---------------------------------------------------------------------------
# Pick a preset from providers.json (gmail, outlook, office365, icloud, yahoo,
# fastmail, gmx, zoho, opensrs). It fills in IMAP/SMTP host, port and security.
MAIL_PROVIDER=gmail

# ...or leave MAIL_PROVIDER empty and set these explicitly (they override the preset):
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURITY=ssl        # "ssl" (port 465) or "starttls" (port 587)

# Credentials for the mailbox that receives the receipts.
IMAP_USER=you@example.com
# App password / mailbox password. NEVER commit this — keep it only in .env or a secret store.
IMAP_PASSWORD=

# ---------------------------------------------------------------------------
# What to collect
# ---------------------------------------------------------------------------
# Sender address of the receipts. A substring works too (e.g. "sl.se" matches any
# sender on that domain).
RECEIPT_SENDER=receipts@vendor.com

INBOX_FOLDER=INBOX
# Processed emails are moved here so they are not picked up again (created if missing).
PROCESSED_FOLDER=Processed/Receipts

# ---------------------------------------------------------------------------
# Report
# ---------------------------------------------------------------------------
RECIPIENT_NAME=Jane Doe
# {name} is replaced by RECIPIENT_NAME.
REPORT_TITLE=Expense report for {name}
# Currency label shown after each amount.
CURRENCY=kr
# Optional "Purpose" column value shown on every row. Leave empty to hide the column.
PURPOSE=

# Optional: a regex to pull a description out of the receipt text (group 1 if present),
# instead of using the first text line. Example for transit tickets:
# DESCRIPTION_MATCH=[A-Za-z]*ticket[A-Za-z ]*
DESCRIPTION_MATCH=

OUTPUT_DIR=./output

# ---------------------------------------------------------------------------
# Delivery & alerts (optional)
# ---------------------------------------------------------------------------
# If set, the report is emailed here on a real run. Leave empty to only produce the file.
ARCHIVE_RECIPIENT=
# Where failure notices go (defaults to IMAP_USER).
NOTIFY_RECIPIENT=
